# MyHujjat.uz — Backend env namunasi
# Haqiqiy qiymatlar uchun .env.prod yarating (commit qilinmaydi)

NODE_ENV=production
PORT=4000

DATABASE_URL=postgresql://myhujjat:GENERATE_PASSWORD@postgres:5432/myhujjat
DB_PASSWORD=GENERATE_PASSWORD

JWT_SECRET=GENERATE_64_HEX
JWT_REFRESH_SECRET=GENERATE_64_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

REDIS_URL=redis://redis:6379

ENCRYPTION_KEY=GENERATE_64_HEX

FRONTEND_URL=https://your-domain.com

ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-domain.com

SOLIQ_API_KEY=
SOLIQ_API_URL=https://my3.soliq.uz/api/remote-access-api/company/info/%s

DIDOX_API_URL=https://api.didox.uz
DIDOX_API_KEY=
DIDOX_WEBHOOK_SECRET=

CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_KEY=

TELEGRAM_BOT_TOKEN=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@your-domain.com
